# Google Cloud / Earth Engine
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GEMINI_API_KEY=your-gemini-api-key

# Database (overridden by docker-compose, but needed for local dev)
DATABASE_URL=postgresql://cultiveai:cultiveai@localhost:5432/cultiveai

# Security - JWT
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL (used by docker-compose)
POSTGRES_USER=cultiveai
POSTGRES_PASSWORD=cultiveai
POSTGRES_DB=cultiveai
